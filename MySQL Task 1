-- Create the database
CREATE DATABASE travel_db;
USE travel_db;

-- Create the travel table
CREATE TABLE travel (
    booking_id INT PRIMARY KEY,
    customer_name VARCHAR(50),
    destination VARCHAR(50),
    category VARCHAR(20),
    ticket_price INT,
    passengers INT
);

-- Insert the sample data
