use company_db;
select * from employee_sales;

select dept, sum(salary) as totalSalary from employee_sales 
group by dept;



select dept, salary, 
row_number() over (partition by dept order by salary desc) 
as ranking
from employee_sales;

select dept, salary, 
rank() over (order by salary desc) 
as ranking
from employee_sales;

select dept, salary, 
row_number() over (order by salary desc) 
as ranking
from employee_sales;

select dept, salary, 
dense_rank() over (order by salary desc) 
as ranking
from employee_sales;


select dept, salary, max(salary) 
over (partition by dept ) as highestSalary from employee_sales;
