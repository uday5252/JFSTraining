-- Display the student_name, marks and grade
-- > 85 ==> A
-- > 65 ==> B
-- > 35 ==> C
-- < 35 ==> F


select student_name, marks,
case
	when marks > 85 then "A"
  when marks > 65 then "B"
  when marks > 35 then "C"
  else "F"
end as grade
from student;


