-- Create Database
CREATE DATABASE company_db;

-- Use Database
USE company_db;

-- Create Table
CREATE TABLE employee_sales (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    dept VARCHAR(20),
    salary DECIMAL(10,2),
    sales INT,
    month VARCHAR(10)
);

